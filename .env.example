# copy this to .env for local testing (never commit the real .env)
# python-dotenv isn't wired up in the code, so either `export $(cat .env | xargs)`
# before running, or just export these in your shell directly

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SUPABASE_URL=
SUPABASE_KEY=

SEARCH_KEYWORDS=forward deployed engineer,solutions engineer,site reliability engineer
SEARCH_LOCATION=remote

MIN_SCORE=6
TOP_N=5

# only needed locally if you don't want to keep resume/resume.txt around
RESUME_TEXT=
